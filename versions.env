# Pinned component versions for M0.2
# Source this file in shell scripts: source versions.env

FIRECRACKER_VERSION=1.10.1
FIRECRACKER_GO_SDK_VERSION=1.0.0

# Guest kernel: Firecracker-provided x86_64 kernel (5.10 series)
# Pre-built at https://s3.amazonaws.com/spec.ccfc.min/img/quickstart_guide/x86_64/kernels/vmlinux.bin
# For a custom build see images/build-kernel.sh
GUEST_KERNEL_VERSION=5.10.225

# Guest OS base
GUEST_OS=ubuntu:22.04

# In-guest agent protocol version (must match client SDK)
AGENT_PROTOCOL_VERSION=1
